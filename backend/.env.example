# Which AI provider to use: "auto" (default), "gemini", "openai", or "none".
# "auto" prefers Gemini (primary): uses GEMINI_API_KEY if set, else OPENAI_API_KEY,
# else falls back to the heuristic parser (no AI).
AI_PROVIDER=auto

# Google Gemini (primary) — drop your key here to switch on real AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (secondary)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
